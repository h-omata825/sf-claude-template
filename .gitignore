#    setup.sh でプロジェクト作成後、この行を削除してから git add を行うこと。
force-app/
manifest/
config/
sfdx-project.json
package.json
jest.config.js
eslint.config.js
.forceignore
.prettierrc
.prettierignore
.husky/
.vscode/

