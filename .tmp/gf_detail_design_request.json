{
  "feature_id": "FG-001",
  "name_ja": "ビザ申込・見積依頼",
  "project_name": "greenfield",
  "author": "ClaudeCode",
  "date": "2026-04-20",

  "summary": "Experience Cloud を通じてお客様が渡航者情報を入力し、ビザ申請要件のプリチェック・コンサルテーション・見積作成依頼を行うまでの一連の申込フロー",
  "purpose": "お客様が渡航者情報を自己入力し、プリチェック → コンサルテーション → 見積依頼 を一連で完結できるようにする。GF社への問い合わせ工数を削減し、申込ミスを防ぐ",
  "users": "お客様（企業の人事・総務担当）、GF社コンサル部・営業部",
  "trigger_screen": "プリチェック画面（preCheck LWC）",
  "trigger": "お客様が Experience Cloud にログインし、申込ボタンを押下",

  "business_flow": [
    {
      "step": 1,
      "actor": "お客様",
      "action": "プリチェック画面でサービス種別・渡航者情報を入力",
      "system": "preCheck",
      "next": [{"to": 2}]
    },
    {
      "step": 2,
      "actor": "システム",
      "action": "ビザ種別・就労形態等の条件に応じてプリチェック判定（OK / リスクあり / NG）",
      "system": "PreCheckController",
      "next": [
        {"condition": "コンサル不要", "to": 5},
        {"condition": "コンサル要", "to": 3}
      ]
    },
    {
      "step": 3,
      "actor": "お客様",
      "action": "コンサルテーション依頼画面で委託担当者・渡航者詳細情報を入力し送信",
      "system": "consultation / consultationModal",
      "next": [{"to": 4}]
    },
    {
      "step": 4,
      "actor": "GFコンサル",
      "action": "コンサル結果をシステムに入力（ConsultingMemo__c を更新）",
      "system": "Salesforce内部",
      "next": [{"to": 5}]
    },
    {
      "step": 5,
      "actor": "お客様",
      "action": "見積作成依頼画面でサービス内容を確認・入力し見積依頼を送信",
      "system": "request / requestModal",
      "next": []
    }
  ],

  "related_objects": [
    {
      "api_name": "BusinessTravelerHeader__c",
      "label": "申請区分",
      "fields": [
        {"api_name": "Name", "label": "申請区分名", "access": "R", "note": ""},
        {"api_name": "Account__c", "label": "取引先", "access": "R", "note": "申請企業"}
      ],
      "relations": []
    },
    {
      "api_name": "BusinessTraveler__c",
      "label": "申請者",
      "fields": [
        {"api_name": "Name", "label": "氏名", "access": "RW", "note": ""},
        {"api_name": "BusinessTravelerHeader__c", "label": "申請区分", "access": "RW", "note": "親レコード"},
        {"api_name": "VisaType__c", "label": "ビザ種別", "access": "RW", "note": "レコードタイプで管理"},
        {"api_name": "Status__c", "label": "ステータス", "access": "RW", "note": "プリチェック→コンサル→見積"}
      ],
      "relations": [
        {"to": "BusinessTravelerHeader__c", "type": "lookup", "label": "申請区分"}
      ]
    },
    {
      "api_name": "ConsultingMemo__c",
      "label": "コンサルメモ",
      "fields": [
        {"api_name": "BusinessTraveler__c", "label": "申請者", "access": "RW", "note": ""},
        {"api_name": "Result__c", "label": "コンサル結果", "access": "RW", "note": ""}
      ],
      "relations": [
        {"to": "BusinessTraveler__c", "type": "lookup", "label": "申請者"}
      ]
    },
    {
      "api_name": "Quote__c",
      "label": "見積",
      "fields": [
        {"api_name": "BusinessTraveler__c", "label": "申請者", "access": "W", "note": "INSERT時に設定"},
        {"api_name": "Account__c", "label": "取引先", "access": "W", "note": "宛先企業"}
      ],
      "relations": [
        {"to": "BusinessTraveler__c", "type": "lookup", "label": "申請者"}
      ]
    },
    {
      "api_name": "QuoteDetail__c",
      "label": "見積明細",
      "fields": [
        {"api_name": "Quote__c", "label": "見積", "access": "W", "note": "親レコード"}
      ],
      "relations": [
        {"to": "Quote__c", "type": "master-detail", "label": "見積"}
      ]
    }
  ],

  "process_steps": [
    {
      "step": 1,
      "title": "マスタデータ取得",
      "description": "PreCheckController.getInitData でサービス種別マスタを取得",
      "component": "PreCheckController",
      "branch": null,
      "next": [{"to": 2}]
    },
    {
      "step": 2,
      "title": "プリチェック判定",
      "description": "ビザ種別・就労形態に応じて申請可否を判定する",
      "component": "PreCheckController",
      "branch": "判定結果",
      "next": [
        {"condition": "OK", "to": 4},
        {"condition": "NG→コンサル要", "to": 3}
      ]
    },
    {
      "step": 3,
      "title": "コンサルテーション依頼",
      "description": "委託担当者候補を取得し、依頼内容をBusinessTraveler__cに保存する",
      "component": "ConsultationController",
      "branch": null,
      "next": [{"to": 4}]
    },
    {
      "step": 4,
      "title": "見積作成",
      "description": "Quote__c / QuoteDetail__cをINSERTし、GF社へ通知メールを送信する",
      "component": "RequestController",
      "branch": null,
      "next": []
    }
  ],

  "components": [
    {
      "api_name": "preCheck",
      "type": "LWC",
      "role": "プリチェック入力・判定結果表示",
      "callees": ["preCheckModal", "PreCheckController"]
    },
    {
      "api_name": "preCheckModal",
      "type": "LWC",
      "role": "プリチェック結果モーダル（判定結果＋次ステップ案内）",
      "callees": []
    },
    {
      "api_name": "consultation",
      "type": "LWC",
      "role": "コンサルテーション依頼情報入力",
      "callees": ["consultationModal", "ConsultationController"]
    },
    {
      "api_name": "consultationModal",
      "type": "LWC",
      "role": "コンサルテーション依頼確認・送信モーダル",
      "callees": []
    },
    {
      "api_name": "request",
      "type": "LWC",
      "role": "見積作成依頼情報入力",
      "callees": ["requestModal", "RequestController"]
    },
    {
      "api_name": "requestModal",
      "type": "LWC",
      "role": "見積作成依頼確認・送信モーダル",
      "callees": []
    },
    {
      "api_name": "PreCheckController",
      "type": "Apex",
      "role": "プリチェック用マスタデータ取得・判定ロジック",
      "callees": []
    },
    {
      "api_name": "ConsultationController",
      "type": "Apex",
      "role": "コンサルテーション依頼の委託担当者候補取得・保存処理",
      "callees": []
    },
    {
      "api_name": "RequestController",
      "type": "Apex",
      "role": "見積作成依頼の初期データ取得・Quote作成・ExternalAccount参照",
      "callees": []
    }
  ],

  "impact": {
    "update_objects": ["BusinessTraveler__c", "Quote__c", "QuoteDetail__c", "ExternalAccount__c"],
    "reference_objects": ["BusinessTravelerHeader__c", "Account", "ConsultingMemo__c"],
    "related_apex": ["PreCheckController", "ConsultationController", "RequestController"],
    "related_flow": [],
    "related_lwc": ["preCheck", "preCheckModal", "consultation", "consultationModal", "request", "requestModal"],
    "external_integrations": ["GF社通知メール（見積依頼後）"],
    "feature_dependencies": []
  },

  "object_access": [
    {"component": "PreCheckController",    "object": "BusinessTravelerHeader__c", "operation": "R"},
    {"component": "PreCheckController",    "object": "BusinessTraveler__c",       "operation": "W"},
    {"component": "ConsultationController","object": "BusinessTraveler__c",       "operation": "W"},
    {"component": "ConsultationController","object": "ConsultingMemo__c",         "operation": "W"},
    {"component": "RequestController",     "object": "BusinessTraveler__c",       "operation": "R"},
    {"component": "RequestController",     "object": "Quote__c",                  "operation": "INSERT"},
    {"component": "RequestController",     "object": "QuoteDetail__c",            "operation": "INSERT"}
  ]
}
